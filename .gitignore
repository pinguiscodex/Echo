.venv
env/
venv/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables
.env

# Data and logs (keep directories but ignore contents)
data/*.wav
data/*.mp3
data/rec_*.wav
data/config.json
