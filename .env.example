# Echo AI Chatbot - Environment Configuration
# Copy this file to .env and fill in your values

# API Provider Selection (openrouter or mistral)
API_PROVIDER=openrouter

# OpenRouter API Configuration (used when API_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Mistral API Configuration (used when API_PROVIDER=mistral)
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# Optional: Whisper Speech-to-Text Model
# Options: tiny, tiny.en, base, base.en, small, small.en, medium, medium.en,
#          large-v1, large-v2, large-v3
# Distilled: distil-large-v3, distil-medium.en, distil-small.en
# Note: Uses faster-whisper (CTranslate2 backend) - 4x faster than original
WHISPER_MODEL=base

# Optional: Text-to-Speech Configuration
# Edge TTS voices: en-US-JennyNeural, en-US-GuyNeural, en-US-AriaNeural
# Other languages: de-DE-KatjaNeural, fr-FR-DeniseNeural, es-ES-ElviraNeural
TTS_VOICE=en-US-JennyNeural

# Optional: Chat Configuration
TEMPERATURE=0.7
MAX_TOKENS=1024
SYSTEM_PROMPT=You are Echo, a helpful and friendly AI assistant. Provide clear, concise answers.

# Optional: Input/Output Configuration
INPUT_MODE=both
OUTPUT_MODE=both

# Optional: Audio Configuration
SAMPLE_RATE=16000

# Optional: AI Agent Tools Configuration
# Enable/disable AI agent tool calling (file operations, code execution, commands)
ENABLE_TOOLS=true

# Timeout for Python code execution (5-120 seconds)
PYTHON_EXECUTION_TIMEOUT=30

# Timeout for shell command execution (5-120 seconds)
COMMAND_EXECUTION_TIMEOUT=30

# Optional: Logging Configuration
LOG_LEVEL=INFO
